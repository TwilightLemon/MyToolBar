<base:FluentWindowBase x:Class="MyToolBar.Views.Windows.SettingsWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:base="clr-namespace:MyToolBar.Common.UIBases;assembly=MyToolBar.Common"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                       xmlns:local="clr-namespace:MyToolBar"
                       xmlns:mb="clr-namespace:MyToolBar.Common.Behaviors;assembly=MyToolBar.Common"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:ws="https://schemas.elecho.dev/wpfsuite"
                       Title="{DynamicResource SettingsWindow_Title}"
                       Width="850"
                       Height="550"
                       Icon="/Resources/icon.ico"
                       ResizeMode="CanMinimize"
                       WindowStyle="None"
                       mc:Ignorable="d">
    <DockPanel>
        <DockPanel Width="200"
                   Background="Transparent"
                   DockPanel.Dock="Left">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Margin="0,10"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="22"
                           FontWeight="Bold"
                           Text="{DynamicResource SettingsWindow_Title}" />
            </StackPanel>
            <ws:ListBox d:ItemsSource="{d:SampleData ItemCount=5}"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{DynamicResource SimpleListBoxItemStyle}"
                        ItemsSource="{Binding ViewModel.SettingsPages}"
                        SelectedItem="{Binding ViewModel.SelectedPage}"
                        SelectionChanged="ListBox_SelectionChanged">
                <ws:ListBox.ItemTemplate>
                    <DataTemplate>
                        <ws:Border Height="40"
                                   Padding="10,0"
                                   d:Background="#3C000000"
                                   Background="Transparent">
                            <ws:StackPanel VerticalAlignment="Center"
                                           Orientation="Horizontal"
                                           Spacing="8">
                                <Border x:Name="FocusedIcon"
                                        Width="3"
                                        Height="16"
                                        Margin="-18,0,0,0"
                                        d:Visibility="Visible"
                                        Background="{DynamicResource SystemThemeColor}"
                                        CornerRadius="1.5"
                                        Visibility="Hidden" />
                                <Path Width="15"
                                      Height="15"
                                      VerticalAlignment="Center"
                                      d:Data="{StaticResource Icon_About}"
                                      Data="{Binding Icon}"
                                      Fill="{DynamicResource ForeColor}"
                                      Stretch="Uniform" />
                                <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                            </ws:StackPanel>
                        </ws:Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}, Path=IsSelected}" Value="True">
                                <Setter TargetName="FocusedIcon" Property="Visibility" Value="Visible" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="FocusedIcon"
                                                             Storyboard.TargetProperty="Height"
                                                             From="0"
                                                             To="16"
                                                             Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}, Path=IsSelected}" Value="False">
                                <Setter TargetName="FocusedIcon" Property="Visibility" Value="Hidden" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ws:ListBox.ItemTemplate>
            </ws:ListBox>
        </DockPanel>
        <ws:Frame Name="WindowFrame"
                  Background="{DynamicResource TabMaskColor}"
                  NavigationUIVisibility="Hidden">
            <ws:Frame.Transition>
                <ws:SlideFadeTransition Distance="50"
                                        Orientation="Vertical"
                                        Duration="0:0:0.200" />
            </ws:Frame.Transition>
        </ws:Frame>
    </DockPanel>
</base:FluentWindowBase>
