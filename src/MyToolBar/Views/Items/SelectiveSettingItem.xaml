<base:ItemBase x:Class="MyToolBar.Views.Items.SelectiveSettingItem"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:base="clr-namespace:MyToolBar.Common.UIBases;assembly=MyToolBar.Common"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:local="clr-namespace:MyToolBar.Views.Items"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               d:DesignWidth="800"
               mc:Ignorable="d">
    <base:ItemBase.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </base:ItemBase.Resources>
    <Grid>
        <Border x:Name="EnabledMask"
                Background="{DynamicResource MaskColor}"
                CornerRadius="15"
                Visibility="{Binding PluginIsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
        <TextBlock Margin="18">
            <Run d:Text="Capsule Name"
                 FontSize="22"
                 Text="{Binding Plugin.DisplayName, Mode=OneWay}" />
            <LineBreak />
            <Run d:Text="Desc." Text="{Binding Plugin.Description, Mode=OneWay}" />
        </TextBlock>
        <Path Width="32"
              Height="32"
              Margin="0,0,36,0"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Data="{DynamicResource Icon_Enabled}"
              Fill="#FF1DE9B6"
              Stretch="Uniform"
              Visibility="{Binding PluginIsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
    </Grid>
</base:ItemBase>
