<base:ItemBase x:Class="MyToolBar.Views.Items.SelectiveSettingItem"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:base="clr-namespace:MyToolBar.Common.UIBases;assembly=MyToolBar.Common"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:local="clr-namespace:MyToolBar.Views.Items"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:ws="https://schemas.elecho.dev/wpfsuite"
               d:DesignWidth="800"
               mc:Ignorable="d">
    <Grid>
        <TextBlock Margin="18">
            <Run d:Text="Capsule Name"
                 FontSize="22"
                 Text="{Binding Plugin.DisplayName, Mode=OneWay}" />
            <LineBreak />
            <Run d:Text="Desc." Text="{Binding Plugin.Description, Mode=OneWay}" />
        </TextBlock>
        <ws:ToggleButton x:Name="EnableToggle"
                         Height="28"
                         Margin="0,0,18,0"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Checked="EnableToggle_Changed"
                         IsChecked="{Binding PluginIsEnabled, Mode=TwoWay}"
                         Style="{DynamicResource RoundToggleButtonStyle}"
                         Unchecked="EnableToggle_Changed" />
    </Grid>
</base:ItemBase>
