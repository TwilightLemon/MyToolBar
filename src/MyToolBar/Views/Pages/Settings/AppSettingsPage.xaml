<Page x:Class="MyToolBar.Views.Pages.Settings.AppSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:common="clr-namespace:MyToolBar.Common;assembly=MyToolBar.Common"
      xmlns:converter="clr-namespace:MyToolBar.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MyToolBar.Views.Pages.Settings"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:service="clr-namespace:MyToolBar.Services"
      xmlns:sys="clr-namespace:System;assembly=netstandard"
      xmlns:vm="clr-namespace:MyToolBar.ViewModels"
      xmlns:ws="https://schemas.elecho.dev/wpfsuite"
      Title="AppSettingsPage"
      d:DataContext="{d:DesignInstance Type=vm:AppSettingsPageViewModel}"
      d:DesignHeight="600"
      d:DesignWidth="800"
      Foreground="{DynamicResource ForeColor}"
      mc:Ignorable="d">
    <Page.Resources>
        <converter:EnumToTextConverter x:Key="EnumToTextConverter" />
        <converter:EnumEqualsConverter x:Key="EnumEqualsConverter" />
        <ObjectDataProvider x:Key="LanguageEnumData"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="common:LocalCulture+Language" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="ProxyModeEnumData"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="service:AppSettings+ProxyMode" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="MainMenuIconEnumData"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="service:AppSettings+MenuIcon" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <DataTemplate x:Key="ComboBoxItemTemplate">
            <TextBlock Text="{Binding Converter={StaticResource EnumToTextConverter}}" />
        </DataTemplate>

        <!--  Tile RadioButton Style: card-style selectable tiles with icon + text  -->
        <Style x:Key="TileRadioButtonStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource ForeColor}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="140" />
            <Setter Property="Height" Value="68" />
            <Setter Property="Padding" Value="8,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="tileBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{DynamicResource MaskColor}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="tileBorder" Property="Background" Value="{DynamicResource SystemThemeColor}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="tileBorder" Property="Background" Value="{DynamicResource FocusMaskColor}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid>
        <ws:ScrollViewer Margin="28,12,28,28" Style="{DynamicResource SimpleVerticalScrollViewerStyle}">
            <ws:StackPanel x:Name="SettingsList" Spacing="8">
                <!--  Appearence settings  -->
                <ws:StackPanel Spacing="8">
                    <TextBlock FontSize="22" Text="{DynamicResource AppSettings_Group_Appearence}" />

                    <!--  Window Mode  -->
                    <Border Padding="4"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Margin="12,8,0,4"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="{DynamicResource AppSettings_Item_WindowMode}" />
                            <Grid Grid.Row="1" Margin="4,4,4,8" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0"
                                             Margin="4,0"
                                             Content="{DynamicResource AS_WindowMode_Embedded}"
                                             IsChecked="{Binding WindowMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static service:AppSettings+WindowMode.Embedded}}"
                                             Style="{StaticResource TileRadioButtonStyle}">
                                    <RadioButton.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Path Width="24"
                                                      Height="24"
                                                      Margin="0,0,0,6"
                                                      HorizontalAlignment="Center"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      Stretch="Uniform">
                                                    <Path.Data>
                                                        <RectangleGeometry RadiusX="2.5"
                                                                           RadiusY="2.5"
                                                                           Rect="4,4 16,16" />
                                                    </Path.Data>
                                                </Path>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           Text="{Binding}"
                                                           TextAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </RadioButton.ContentTemplate>
                                </RadioButton>
                                <RadioButton Grid.Column="1"
                                             Margin="4,0"
                                             Content="{DynamicResource AS_WindowMode_Floating}"
                                             IsChecked="{Binding WindowMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static service:AppSettings+WindowMode.Floating}}"
                                             Style="{StaticResource TileRadioButtonStyle}">
                                    <RadioButton.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Path Width="24"
                                                      Height="24"
                                                      Margin="0,0,0,6"
                                                      HorizontalAlignment="Center"
                                                      Data="{StaticResource Icon_Float}"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      Stretch="Uniform" />
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           Text="{Binding}"
                                                           TextAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </RadioButton.ContentTemplate>
                                </RadioButton>
                            </Grid>
                        </Grid>
                    </Border>

                    <!--  Background Mode  -->
                    <Border Padding="4"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Margin="12,8,0,4"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="{DynamicResource AppSettings_Item_BackgroundMode}" />
                            <Grid Grid.Row="1" Margin="4,4,4,8" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0"
                                             Margin="4,0"
                                             Content="{DynamicResource AS_BackgroundMode_Transparent}"
                                             IsChecked="{Binding BackgroundMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static service:AppSettings+BackgroundMode.Transparent}}"
                                             Style="{StaticResource TileRadioButtonStyle}">
                                    <RadioButton.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Path Width="24"
                                                      Height="24"
                                                      Margin="0,0,0,6"
                                                      HorizontalAlignment="Center"
                                                      Data="{StaticResource Icon_Transparent}"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      Stretch="Uniform" />
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           Text="{Binding}"
                                                           TextAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </RadioButton.ContentTemplate>
                                </RadioButton>
                                <RadioButton Grid.Column="1"
                                             Margin="4,0"
                                             Content="{DynamicResource AS_BackgroundMode_Acrylic}"
                                             IsChecked="{Binding BackgroundMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static service:AppSettings+BackgroundMode.Acrylic}}"
                                             Style="{StaticResource TileRadioButtonStyle}">
                                    <RadioButton.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Path Width="24"
                                                      Height="24"
                                                      Margin="0,0,0,6"
                                                      HorizontalAlignment="Center"
                                                      Data="{StaticResource Icon_Blur}"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      Stretch="Uniform" />
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           Text="{Binding}"
                                                           TextAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </RadioButton.ContentTemplate>
                                </RadioButton>
                            </Grid>
                        </Grid>
                    </Border>

                    <!--  Immerse Mode  -->
                    <Border Padding="4"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Margin="12,8,0,4"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="{DynamicResource AppSettings_Item_ImmerseMode}" />
                            <Grid Grid.Row="1" Margin="4,4,4,8" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0"
                                             Margin="4,0"
                                             Content="{DynamicResource AS_ImmerseMode_Off}"
                                             IsChecked="{Binding ImmerseMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static service:AppSettings+ImmerseMode.Off}}"
                                             Style="{StaticResource TileRadioButtonStyle}">
                                    <RadioButton.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Path Width="24"
                                                      Height="24"
                                                      Margin="0,0,0,6"
                                                      HorizontalAlignment="Center"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      Stretch="Uniform">
                                                    <Path.Data>
                                                        <CombinedGeometry GeometryCombineMode="Exclude">
                                                            <CombinedGeometry.Geometry1>
                                                                <EllipseGeometry Center="12,12"
                                                                                 RadiusX="9"
                                                                                 RadiusY="9" />
                                                            </CombinedGeometry.Geometry1>
                                                            <CombinedGeometry.Geometry2>
                                                                <RectangleGeometry Rect="5,10 14,4">
                                                                    <RectangleGeometry.Transform>
                                                                        <RotateTransform Angle="45" CenterX="12" CenterY="12" />
                                                                    </RectangleGeometry.Transform>
                                                                </RectangleGeometry>
                                                            </CombinedGeometry.Geometry2>
                                                        </CombinedGeometry>
                                                    </Path.Data>
                                                </Path>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           Text="{Binding}"
                                                           TextAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </RadioButton.ContentTemplate>
                                </RadioButton>
                                <RadioButton Grid.Column="1"
                                             Margin="4,0"
                                             Content="{DynamicResource AS_ImmerseMode_Auto}"
                                             IsChecked="{Binding ImmerseMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static service:AppSettings+ImmerseMode.Auto}}"
                                             Style="{StaticResource TileRadioButtonStyle}">
                                    <RadioButton.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Path Width="24"
                                                      Height="24"
                                                      Margin="0,0,0,6"
                                                      HorizontalAlignment="Center"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      Stretch="Uniform">
                                                    <Path.Data>
                                                        <CombinedGeometry GeometryCombineMode="Exclude">
                                                            <CombinedGeometry.Geometry1>
                                                                <EllipseGeometry Center="12,12"
                                                                                 RadiusX="9"
                                                                                 RadiusY="9" />
                                                            </CombinedGeometry.Geometry1>
                                                            <CombinedGeometry.Geometry2>
                                                                <RectangleGeometry Rect="2,2 10,20" />
                                                            </CombinedGeometry.Geometry2>
                                                        </CombinedGeometry>
                                                    </Path.Data>
                                                </Path>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           Text="{Binding}"
                                                           TextAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </RadioButton.ContentTemplate>
                                </RadioButton>
                                <RadioButton Grid.Column="2"
                                             Margin="4,0"
                                             Content="{DynamicResource AS_ImmerseMode_Always}"
                                             IsChecked="{Binding ImmerseMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static service:AppSettings+ImmerseMode.Always}}"
                                             Style="{StaticResource TileRadioButtonStyle}">
                                    <RadioButton.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Path Width="24"
                                                      Height="24"
                                                      Margin="0,0,0,6"
                                                      HorizontalAlignment="Center"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      Stretch="Uniform">
                                                    <Path.Data>
                                                        <EllipseGeometry Center="12,12"
                                                                         RadiusX="9"
                                                                         RadiusY="9" />
                                                    </Path.Data>
                                                </Path>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           Text="{Binding}"
                                                           TextAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </RadioButton.ContentTemplate>
                                </RadioButton>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Height="48"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <ToggleButton Margin="12,0,12,0"
                                      Content="{DynamicResource AppSettings_Item_EnableIsland}"
                                      IsChecked="{Binding EnableIsland}"
                                      Style="{DynamicResource RoundToggleButtonStyle}" />
                    </Border>
                    <Border Height="48"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <Grid>
                            <TextBlock Margin="12"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource AppSettings_Item_Language}" />
                            <ws:ComboBox x:Name="LanguageComboBox"
                                         Height="24"
                                         Margin="0,0,48,0"
                                         HorizontalAlignment="Right"
                                         ItemTemplate="{DynamicResource ComboBoxItemTemplate}"
                                         ItemsSource="{Binding Source={StaticResource LanguageEnumData}}"
                                         SelectedItem="{Binding AppLanguage}"
                                         Style="{StaticResource SimpleComboBoxStyleForWs}" />
                        </Grid>
                    </Border>
                    <Border Height="48"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <Grid>
                            <TextBlock Margin="12"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource AppSettings_Item_MainMenuIcon}" />
                            <ws:ComboBox x:Name="MainMenuIconCombox"
                                         Height="24"
                                         Margin="0,0,48,0"
                                         HorizontalAlignment="Right"
                                         ItemTemplate="{DynamicResource ComboBoxItemTemplate}"
                                         ItemsSource="{Binding Source={StaticResource MainMenuIconEnumData}}"
                                         SelectedItem="{Binding MainMenuIcon}"
                                         Style="{StaticResource SimpleComboBoxStyleForWs}" />
                        </Grid>
                    </Border>
                    <Border Height="48"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <Grid>
                            <TextBlock Margin="12"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource AppSettings_Item_Font}" />
                            <ws:TextBox x:Name="AppFontTB"
                                        Height="30"
                                        MinWidth="220"
                                        Margin="0,0,48,0"
                                        Padding="8,0"
                                        HorizontalAlignment="Right"
                                        VerticalContentAlignment="Center"
                                        PreviewKeyDown="AppFontTB_PreviewKeyDown"
                                        Style="{StaticResource SimpleTextBoxStyleForWs}"
                                        Text="{Binding AppFont}"
                                        ToolTip="{DynamicResource AppSettings_Item_FontTbHint}" />
                        </Grid>
                    </Border>
                </ws:StackPanel>
                <!--  Behaviors settings  -->
                <ws:StackPanel Margin="0,10,0,0" Spacing="8">
                    <TextBlock FontSize="22" Text="{DynamicResource AppSettings_Group_Behavior}" />
                    <Border Background="{DynamicResource MaskColor}" CornerRadius="12">
                        <Grid>
                            <TextBlock Margin="12,18,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="top"
                                       Text="{DynamicResource AppSettings_Item_WebProxy_ProxyMode}" />
                            <ws:ComboBox x:Name="ProxyModeComboBox"
                                         Width="98"
                                         Height="24"
                                         Margin="0,12,48,0"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         ItemTemplate="{DynamicResource ComboBoxItemTemplate}"
                                         ItemsSource="{Binding Source={StaticResource ProxyModeEnumData}}"
                                         SelectedItem="{Binding ProxyMode}"
                                         Style="{StaticResource SimpleComboBoxStyleForWs}" />
                            <ws:TextBox x:Name="ProxyAddressTextBox"
                                        Width="160"
                                        Height="30"
                                        Margin="12,48,48,0"
                                        Padding="6,6,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Placeholder="{DynamicResource AppSettings_Item_WebProxy_ProxyAddress}"
                                        Style="{StaticResource SimpleTextBoxStyleForWs}"
                                        Text="{Binding ProxyConf.Address}" />
                            <ws:TextBox x:Name="ProxyPortTextBox"
                                        Width="72"
                                        Height="30"
                                        Margin="180,48,48,0"
                                        Padding="6,6,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Placeholder="{DynamicResource AppSettings_Item_WebProxy_ProxyPort}"
                                        Style="{StaticResource SimpleTextBoxStyleForWs}"
                                        Text="{Binding ProxyConf.Port}" />
                            <ws:TextBox x:Name="ProxyUsernameTextBox"
                                        Width="160"
                                        Height="30"
                                        Margin="12,84,48,12"
                                        Padding="6,6,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Placeholder="{DynamicResource AppSettings_Item_WebProxy_ProxyUsername}"
                                        Style="{StaticResource SimpleTextBoxStyleForWs}"
                                        Text="{Binding ProxyConf.UserName}" />
                            <ws:PasswordBox x:Name="ProxyPasswordBox"
                                            Width="160"
                                            Height="30"
                                            Margin="180,84,48,12"
                                            Padding="6,6,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Password="{Binding ProxyConf.Pwd}"
                                            Placeholder="{DynamicResource AppSettings_Item_WebProxy_ProxyPassword}"
                                            Style="{StaticResource SimplePasswordBoxStyleForWs}" />
                        </Grid>
                    </Border>
                    <Border Height="48"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <ToggleButton x:Name="AutoRunCb"
                                      Margin="12,0,12,0"
                                      Content="{DynamicResource AppSettings_Item_AutoRunAtStartup}"
                                      IsChecked="{Binding AutoRunAtStartup}"
                                      Style="{DynamicResource RoundToggleButtonStyle}" />
                    </Border>
                    <Border Height="48"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <ToggleButton Margin="12,0,12,0"
                                      Content="{DynamicResource AppSettings_Item_EnableHideWhenFullScreen}"
                                      IsChecked="{Binding HideWhenFullScreen}"
                                      Style="{DynamicResource RoundToggleButtonStyle}" />
                    </Border>
                    <Border Height="48"
                            Background="{DynamicResource MaskColor}"
                            CornerRadius="12">
                        <ToggleButton Margin="12,0,12,0"
                                      Content="{DynamicResource AppSettings_Item_EnableWindowControl}"
                                      IsChecked="{Binding EnableWindowControl}"
                                      Style="{DynamicResource RoundToggleButtonStyle}" />
                    </Border>
                </ws:StackPanel>
            </ws:StackPanel>
        </ws:ScrollViewer>
    </Grid>
</Page>
