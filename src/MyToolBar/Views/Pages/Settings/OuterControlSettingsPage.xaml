<Page x:Class="MyToolBar.Views.Pages.Settings.OuterControlSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MyToolBar.Views.Pages.Settings"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ws="https://schemas.elecho.dev/wpfsuite"
      Title="OuterControlSettingsPage"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Foreground="{DynamicResource ForeColor}"
      mc:Ignorable="d">

    <DockPanel>
        <ws:StackPanel Height="64"
                       DockPanel.Dock="Top"
                       Orientation="Horizontal"
                       Spacing="20">
            <TextBlock Margin="20,0,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="20"
                       FontWeight="Bold"
                       Text="{DynamicResource SettingsWindow_Tab_OuterControl}" />
            <ws:Button Height="32"
                       Padding="12,4"
                       Click="RemoveOuterControlBtn_Click"
                       Content="{DynamicResource OuterControlSettings_Remove}"
                       Style="{StaticResource SimpleButtonStyleForWs}"
                       WindowChrome.IsHitTestVisibleInChrome="True" />
        </ws:StackPanel>
        <ws:ListBox x:Name="OCPluginList"
                    Margin="20,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    d:ItemsSource="{d:SampleData ItemCount=5}"
                    Background="{DynamicResource TabMaskColor}"
                    BorderBrush="{DynamicResource TabBorderColor}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ItemContainerStyle="{DynamicResource SimpleListBoxItemStyle}"
                    ItemsSource="{Binding}"
                    SelectionChanged="OCPluginList_SelectionChanged">
            <ws:ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Height="Auto"
                            Padding="18"
                            Background="Transparent">
                        <ws:StackPanel>
                            <TextBlock FontSize="18" Text="{Binding DisplayName, Mode=OneWay}" />
                            <TextBlock FontSize="12"
                                       Opacity="0.6"
                                       Text="{Binding Description, Mode=OneWay}" />
                        </ws:StackPanel>
                    </Border>
                </DataTemplate>
            </ws:ListBox.ItemTemplate>
        </ws:ListBox>
    </DockPanel>
</Page>
