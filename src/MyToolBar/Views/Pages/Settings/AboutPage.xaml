<Page x:Class="MyToolBar.Views.Pages.Settings.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MyToolBar.Views.Pages.Settings"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ws="https://schemas.elecho.dev/wpfsuite"
      Title="AboutPage"
      d:Background="White"
      d:DesignHeight="550"
      d:DesignWidth="800"
      d:Foreground="Black"
      Foreground="{DynamicResource ForeColor}"
      mc:Ignorable="d">

    <ws:ScrollViewer Margin="28,12,28,28" Style="{DynamicResource SimpleVerticalScrollViewerStyle}">
        <ws:StackPanel Spacing="12">
            <!--  Title  -->
            <TextBlock Margin="0,0,0,8"
                       FontSize="22"
                       Text="{DynamicResource SettingsWindow_Tab_About}" />

            <!--  Card 1: App Info  -->
            <Border Padding="24" Style="{StaticResource BorderCardStyle}">
                <ws:StackPanel HorizontalAlignment="Center" Spacing="10">
                    <Image Width="64"
                           Height="64"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="/Resources/icon.ico" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="28"
                               FontWeight="Bold"
                               Text="MyToolBar" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="14"
                               Opacity="0.8">
                        <Run Text="{DynamicResource SettingsWindow_Version}" />
                        <Run Text=": " />
                        <Run Text="{Binding AppVersion, Mode=OneTime}" />
                    </TextBlock>
                    <TextBlock MaxWidth="420"
                               FontSize="13"
                               Opacity="0.7"
                               Text="{DynamicResource AboutPage_AppDescription}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </ws:StackPanel>
            </Border>

            <!--  Card 2: Author & License Info  -->
            <Border Padding="24" Style="{StaticResource BorderCardStyle}">
                <ws:StackPanel Spacing="8">
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{DynamicResource AboutPage_Author}" />
                    <TextBlock FontSize="13"
                               Opacity="0.7"
                               Text="{DynamicResource AboutPage_AuthorValue}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="{DynamicResource AboutPage_License}" />
                    <TextBlock FontSize="13"
                               Opacity="0.7"
                               Text="{DynamicResource AboutPage_OpenSourceNote}"
                               TextWrapping="Wrap" />
                    <TextBlock FontSize="13">
                        <Hyperlink Click="GitHubLink_Click"
                                   Foreground="{DynamicResource SystemThemeColor}"
                                   TextDecorations="None">
                            <Run Text="{DynamicResource AboutPage_ProjectLink}" />
                        </Hyperlink>
                    </TextBlock>
                </ws:StackPanel>
            </Border>

            <!--  Card 3: Third-Party Libraries  -->
            <Border Padding="24" Style="{StaticResource BorderCardStyle}">
                <ws:StackPanel Spacing="6">
                    <TextBlock Margin="0,0,0,4"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="{DynamicResource AboutPage_ThirdPartyTitle}" />
                    <ItemsControl ItemsSource="{Binding ThirdPartyLibraries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="13"
                                           Opacity="0.7"
                                           Text="{Binding StringFormat='· {0}'}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ws:StackPanel>
            </Border>

            <Border Padding="24" Style="{StaticResource BorderCardStyle}">
                <ws:StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="14"
                               Opacity="0.6"
                               TextAlignment="Center">
                        <Run Text="Built with" />
                        <Run Foreground="OrangeRed" Text="❤️" />
                        <Run Text="using .NET 8 and WPF" />
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="14"
                               Opacity="0.6"
                               Text="Thank you for using MyToolBar!"
                               TextAlignment="Center" />
                </ws:StackPanel>
            </Border>
        </ws:StackPanel>
    </ws:ScrollViewer>
</Page>
