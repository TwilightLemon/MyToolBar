<Page x:Class="MyToolBar.Views.Pages.Settings.PackagePluginSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MyToolBar.Views.Pages.Settings"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ws="https://schemas.elecho.dev/wpfsuite"
      Title="PackagePluginSettingsPage"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Foreground="{DynamicResource ForeColor}"
      mc:Ignorable="d">
    <!--  主内容区域  -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  顶栏：返回 + 标题  -->
        <Grid Grid.Row="0" Margin="20,16,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ws:Button x:Name="BackBtn"
                       Grid.Column="0"
                       Height="32"
                       Padding="12,0"
                       Click="BackBtn_Click"
                       Content="{DynamicResource SettingsWindow_Back}"
                       CornerRadius="8"
                       FontSize="14"
                       Style="{StaticResource SimpleButtonStyleForWs}"
                       WindowChrome.IsHitTestVisibleInChrome="True" />
            <TextBlock x:Name="PageTitle"
                       Grid.Column="1"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="20"
                       FontWeight="Bold"
                       Text="{DynamicResource SettingsWindow_PackageConfig}" />
        </Grid>

        <!--  设置项列表  -->
        <ws:ScrollViewer Grid.Row="1" Style="{StaticResource SimpleVerticalScrollViewerStyle}">
            <StackPanel x:Name="SettingsPanel" />
        </ws:ScrollViewer>

        <!--  底栏：Apply 按钮  -->
        <Grid Grid.Row="2" Margin="20,8,20,16">
            <ws:Button x:Name="ApplyBtn"
                       Width="120"
                       Height="36"
                       HorizontalAlignment="Right"
                       Click="ApplyBtn_Click"
                       Content="{DynamicResource SettingsWindow_Apply}"
                       CornerRadius="8"
                       FontSize="14"
                       Style="{StaticResource AccentButtonStyleForWs}" />
        </Grid>
    </Grid>
</Page>
