<base:ItemBase x:Class="MyToolBar.Plugin.BasicPackage.SystemMonitor.Views.ProcessItem"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:base="clr-namespace:MyToolBar.Common.UIBases;assembly=MyToolBar.Common"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               Width="330"
               Height="40"
               Background="Transparent"
               mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="19*" />
            <ColumnDefinition Width="10*" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="ProName"
                   Margin="20,0,5,0"
                   VerticalAlignment="Center"
                   d:Text="Lemon App"
                   FontSize="14" />
        <TextBlock x:Name="InfoTb"
                   Grid.Column="1"
                   Margin="0,0,15,0"
                   VerticalAlignment="Center"
                   d:Text="MEM  300MB"
                   FontSize="14"
                   FontWeight="Bold"
                   TextAlignment="Right" />
    </Grid>
</base:ItemBase>
