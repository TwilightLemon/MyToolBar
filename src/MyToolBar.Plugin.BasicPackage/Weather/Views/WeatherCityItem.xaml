<base:ItemBase x:Class="MyToolBar.Plugin.BasicPackage.Weather.Views.WeatherCityItem"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:base="clr-namespace:MyToolBar.Common.UIBases;assembly=MyToolBar.Common"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:local="clr-namespace:MyToolBar.Plugin.BasicPackage.Weather.Views"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:ws="https://schemas.elecho.dev/wpfsuite"
               Width="330"
               Height="40"
               Command="{Binding DataContext.SelectCityCommand, RelativeSource={RelativeSource AncestorType=local:WeatherBox}}"
               CommandParameter="{Binding}"
               mc:Ignorable="d">
    <base:ItemBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MyToolBar.Common;component/Styles/IconData.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MyToolBar.Common;component/Styles/UITemplate.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </base:ItemBase.Resources>
    <Grid>
        <!--  收藏按钮: 使用标准 ws:Button  -->
        <ws:Button x:Name="AddFavorBtn"
                   Width="25"
                   Height="24"
                   Margin="0,0,20,0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Command="{Binding DataContext.ToggleFavorCityCommand, RelativeSource={RelativeSource AncestorType=local:WeatherBox}}"
                   CommandParameter="{Binding}"
                   CornerRadius="10"
                   Style="{StaticResource SimpleButtonStyleForWs}">
            <Path x:Name="FavorIcon"
                  Width="15"
                  ClipToBounds="True"
                  Data="{StaticResource Icon_favor}"
                  Stretch="Uniform"
                  Stroke="{DynamicResource ForeColor}"
                  StrokeThickness="2" />
        </ws:Button>
        <!--  城市名称  -->
        <TextBlock Margin="20,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   d:Text="ShangHai Pudong Dictrict"
                   FontSize="14"
                   FontWeight="Bold"
                   Text="{Binding DisplayName}" />
    </Grid>
</base:ItemBase>
