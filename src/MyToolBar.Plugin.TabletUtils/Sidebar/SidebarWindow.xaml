<Window x:Class="MyToolBar.Plugin.TabletUtils.Sidebar.SidebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mb="clr-namespace:MyToolBar.Common.Behaviors;assembly=MyToolBar.Common"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ws="https://schemas.elecho.dev/wpfsuite"
        Title="Sidebar"
        Width="500"
        Height="600"
        d:Background="Transparent"
        ws:WindowOption.Corner="Round"
        Background="{DynamicResource WindowBackgroundColor}"
        Foreground="{DynamicResource ForeColor}"
        Left="0"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Top="36"
        Topmost="True"
        WindowStyle="None"
        mc:Ignorable="d">
    <i:Interaction.Behaviors>
        <mb:BlurWindowBehavior IsToolWindow="True" Mode="Acrylic" />
    </i:Interaction.Behaviors>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MyToolBar.Plugin.TabletUtils;component/IconData.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MyToolBar.Common;component/Styles/UITemplate.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" MinHeight="160" />
        </Grid.RowDefinitions>
        <Grid Background="Transparent">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12">
                XXX
            </TextBlock>
            <ws:ToggleButton x:Name="FixTb"
                             Margin="0,0,12,0"
                             Padding="12,4"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Background="{DynamicResource MaskColor}"
                             BorderThickness="0"
                             CheckedBackground="{DynamicResource SystemThemeColor}"
                             CheckedForeground="{DynamicResource ForeColor}"
                             CornerRadius="12"
                             Foreground="{DynamicResource ForeColor}"
                             HoverBackground="{DynamicResource SystemThemeColor}"
                             HoverForeground="{DynamicResource ForeColor}"
                             PressedBackground="{DynamicResource SystemThemeColor}">
                Fix
            </ws:ToggleButton>
            <ws:Button x:Name="ClearBtn"
                       Margin="12,0,0,0"
                       Padding="12,4"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Background="{DynamicResource MaskColor}"
                       BorderThickness="0"
                       CornerRadius="12"
                       Foreground="{DynamicResource ForeColor}"
                       HoverBackground="{DynamicResource SystemThemeColor}"
                       HoverForeground="{DynamicResource ForeColor}"
                       PressedBackground="{DynamicResource SystemThemeColor}"
                       PressedForeground="{DynamicResource ForeColor}">
                Clear
            </ws:Button>
        </Grid>
        <Grid Grid.Row="1">
            <ws:ScrollViewer Style="{StaticResource SimpleVerticalScrollViewerStyle}">
                <ws:StackPanel x:Name="MsgContainer"
                               Margin="12,0"
                               Spacing="12" />
            </ws:ScrollViewer>
        </Grid>
        <Border Grid.Row="2"
                Margin="12"
                Background="{DynamicResource MaskColor}"
                CornerRadius="12">
            <Grid>
                <ws:TextBox x:Name="tb"
                            MaxHeight="400"
                            Margin="4,4,4,48"
                            Padding="8"
                            AcceptsReturn="True"
                            AcceptsTab="True"
                            Background="Transparent"
                            CornerRadius="0"
                            FocusedBackground="Transparent"
                            HoverBackground="Transparent"
                            Placeholder="Message"
                            Style="{StaticResource SimpleTextBoxStyleForWs}"
                            TextWrapping="Wrap" />
                <ws:ToggleButton Height="28"
                                 Margin="18"
                                 Padding="12,4"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Bottom"
                                 Background="{DynamicResource MaskColor}"
                                 BorderThickness="0"
                                 CheckedBackground="{DynamicResource SystemThemeColor}"
                                 CheckedForeground="{DynamicResource ThemedForeColor}"
                                 CornerRadius="14"
                                 Cursor="Hand"
                                 Foreground="{DynamicResource ThemedForeColor}"
                                 HoverBackground="{DynamicResource SystemThemeColor}"
                                 HoverForeground="{DynamicResource ThemedForeColor}"
                                 PressedBackground="{DynamicResource SystemThemeColor}">
                    XXXXX
                </ws:ToggleButton>
                <ws:Button x:Name="SendBtn"
                           Width="42"
                           Height="42"
                           Margin="0,0,12,12"
                           Padding="12,4"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Background="{DynamicResource SystemThemeColor}"
                           BorderThickness="0"
                           Click="SendBtn_Click"
                           CornerRadius="21"
                           Cursor="Hand"
                           Foreground="{DynamicResource ThemedForeColor}"
                           HoverBackground="{DynamicResource SystemThemeColor}"
                           HoverForeground="{DynamicResource ThemedForeColor}"
                           PressedBackground="{DynamicResource SystemThemeColor}"
                           PressedForeground="{DynamicResource ThemedForeColor}">
                    <Path x:Name="SendingStatus"
                          Margin="2"
                          Data="{StaticResource SendIcon}"
                          Fill="{DynamicResource ThemedForeColor}"
                          Stretch="Uniform" />
                </ws:Button>
            </Grid>
        </Border>
    </Grid>
</Window>
